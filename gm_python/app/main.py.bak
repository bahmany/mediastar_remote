@app.get("/protocol", response_class=HTMLResponse)
async def protocol_page(request: Request) -> Any:
    login_info = getattr(app.state, "login_info", None)
    error = getattr(app.state, "last_error", None)
    app.state.last_error = None

    md_path = Path(__file__).resolve().parent.parent / "MEDIASTAR_4030_4K_PROTOCOL.md"
    try:
        md_text = md_path.read_text(encoding="utf-8", errors="ignore")
    except OSError:
        md_text = "Protocol file not found."

    return templates.TemplateResponse(
        "protocol.html",
        {
            "request": request,
            "login_info": login_info,
            "error": error,
            "md_text": md_text,
        },
    )


