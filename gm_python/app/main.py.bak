def _resolve_channel_by_index(client: Any, index: int) -> dict[str, Any] | None:
    try:
        for ch in client.state.channels:
            if not isinstance(ch, dict):
                continue
            idx = ch.get("ProgramIndex", ch.get("ServiceIndex", -1))
            try:
                if int(idx) == int(index):
                    return ch
            except Exception:
                continue
    except Exception:
        return None
    return None


def _resolve_program_id(ch: dict[str, Any] | None, fallback_index: int) -> str:
    if not ch:
        return str(fallback_index)
    for k in ("ProgramId", "ServiceID", "ServiceId", "ServiceID "):
        if k in ch and ch.get(k) not in (None, ""):
            return str(ch.get(k))
    return str(fallback_index)


def _resolve_tv_state(ch: dict[str, Any] | None) -> int:
    if not ch:
        return 0
    for k in ("ChannelType", "Radio", "TvState"):
        if k in ch and ch.get(k) not in (None, ""):
            try:
                return int(ch.get(k))
            except Exception:
                pass
    return 0


@app.post("/api/fav/toggle")
async def api_fav_toggle(index: int = Form(...), fav: int = Form(...), group_ids: str = Form("")) -> Any:
    client, _login_info = _connected_client()
    if client is None:
        return {"ok": False}

    ch = _resolve_channel_by_index(client, int(index))
    program_id = _resolve_program_id(ch, int(index))
    tv_state = _resolve_tv_state(ch)

    gids: list[int] = []
    try:
        if group_ids.strip():
            gids = [int(x) for x in group_ids.split(",") if x.strip()]
    except Exception:
        gids = []

    try:
        await asyncio.to_thread(
            client.set_channel_fav_mark,
            tv_state=tv_state,
            fav_mark=int(fav),
            favor_group_ids=gids,
            program_ids=[program_id],
        )
        return {"ok": True}
    except STBConnectionError as e:
        return {"ok": False, "error": str(e)}


def _parse_force_flag(force: str | None) -> bool:
    if force is None:
        return False
    return str(force).strip().lower() in {"1", "true", "yes", "on"}


@app.post("/api/keyboard/keycode")
async def api_keyboard_keycode(key_code: int = Form(...), force: str = Form("0")) -> Any:
    client, _login_info = _connected_client()
    if client is None:
        return {"ok": False}

    try:
        await asyncio.to_thread(client.send_input_keycode, int(key_code), force=_parse_force_flag(force))
        return {"ok": True}
    except STBConnectionError as e:
        return {"ok": False, "error": str(e)}


@app.post("/api/keyboard/text")
async def api_keyboard_text(text: str = Form(...), force: str = Form("0")) -> Any:
    client, _login_info = _connected_client()
    if client is None:
        return {"ok": False}

    try:
        await asyncio.to_thread(client.send_text, str(text), force=_parse_force_flag(force))
        return {"ok": True}
    except STBConnectionError as e:
        return {"ok": False, "error": str(e)}


