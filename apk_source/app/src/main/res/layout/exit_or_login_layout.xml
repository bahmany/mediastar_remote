<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center"
        android:background="@drawable/disp_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/middle_text_size"
            android:textColor="@color/title_text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/exit_or_login_list"/>
    </LinearLayout>
    <TextView
        android:textSize="@dimen/middle_text_size"
        android:textColor="@color/title_text_color"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/space_of_to_left_side_size"
        android:layout_marginTop="@dimen/exit_or_login_space_of_to_top_or_buttom_side_size"
        android:layout_marginRight="@dimen/space_of_to_left_side_size"
        android:text="@string/exit_or_login_text"/>
    <RelativeLayout
        android:id="@+id/login_list_relative"
        android:background="@drawable/exit_or_login_backgroud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/space_of_to_left_side_size"
        android:layout_marginTop="@dimen/exit_or_login_space_of_to_text_view_side_size"
        android:layout_marginRight="@dimen/space_of_to_left_side_size">
        <ImageView
            android:id="@+id/login_list_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
            android:src="@drawable/login_list_icon"
            android:layout_centerVertical="true"/>
        <TextView
            android:textSize="@dimen/middle_text_size"
            android:textColor="@android:color/black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/exit_or_login_space_between_image_and_text"
            android:text="@string/login_list"
            android:layout_toRightOf="@+id/login_list_icon"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/exit_app_relative"
        android:background="@drawable/exit_or_login_backgroud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/space_of_to_left_side_size"
        android:layout_marginTop="@dimen/padding_top_bottom_of_edittext_background"
        android:layout_marginRight="@dimen/space_of_to_left_side_size">
        <ImageView
            android:id="@+id/exit_app"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
            android:src="@drawable/exit_app_icon"
            android:layout_centerVertical="true"/>
        <TextView
            android:textSize="@dimen/middle_text_size"
            android:textColor="@android:color/black"
            android:id="@+id/exit_app_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/exit_or_login_space_between_image_and_text"
            android:text="@string/exit"
            android:layout_toRightOf="@+id/exit_app"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <RelativeLayout
        android:id="@+id/cancel_relative"
        android:background="@drawable/exit_or_login_backgroud"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/space_of_to_left_side_size"
        android:layout_marginTop="@dimen/padding_top_bottom_of_edittext_background"
        android:layout_marginRight="@dimen/space_of_to_left_side_size"
        android:layout_marginBottom="@dimen/exit_or_login_space_of_to_top_or_buttom_side_size">
        <ImageView
            android:id="@+id/cancel_icon"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
            android:src="@drawable/cancel_icon"
            android:layout_centerVertical="true"/>
        <TextView
            android:textSize="@dimen/middle_text_size"
            android:textColor="@android:color/black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/exit_or_login_space_between_image_and_text"
            android:text="@string/cancel_str"
            android:layout_toRightOf="@+id/cancel_icon"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
</LinearLayout>
