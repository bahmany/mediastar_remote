<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/backgound2"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:background="@drawable/disp_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/large_text_size"
            android:textColor="@color/title_text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/popup_window_option_stb_info"
            android:layout_centerInParent="true"/>
        <Button
            android:id="@+id/back_stb_info"
            android:background="@drawable/return_button_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <LinearLayout
        android:gravity="center_horizontal"
        android:orientation="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginTop="@dimen/about_me_content_top_margin">
        <ImageView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/display_stb_icon"/>
        <RelativeLayout
            android:background="@drawable/add_back1"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
            android:layout_marginTop="@dimen/stb_info_item_margin_top_logo"
            android:layout_marginRight="@dimen/space_of_to_mobile_side_size">
            <TextView
                android:textSize="@dimen/middle_text_size"
                android:textColor="@color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/stb_info_item_name_margin_left"
                android:text="@string/stb_status"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="@dimen/middle_text_size"
                android:textColor="@color/deep_blue"
                android:id="@+id/stb_info_status"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/stb_info_item_text_margin_left"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:background="@drawable/add_time_up_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
            android:layout_marginTop="@dimen/stb_info_item_margin_top_item"
            android:layout_marginRight="@dimen/space_of_to_mobile_side_size">
            <TextView
                android:textSize="@dimen/middle_text_size"
                android:textColor="@color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/stb_info_item_name_margin_left"
                android:text="@string/producted_name"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="@dimen/middle_text_size"
                android:textColor="@color/deep_blue"
                android:id="@+id/stb_info_product_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/stb_info_item_text_margin_left"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:background="@drawable/add_time_mid_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
            android:layout_marginRight="@dimen/space_of_to_mobile_side_size">
            <TextView
                android:textSize="@dimen/middle_text_size"
                android:textColor="@color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/stb_info_item_name_margin_left"
                android:text="@string/software_version"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="@dimen/middle_text_size"
                android:textColor="@color/deep_blue"
                android:id="@+id/stb_info_software_version"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/stb_info_item_text_margin_left"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:background="@drawable/add_time_mid_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
            android:layout_marginRight="@dimen/space_of_to_mobile_side_size">
            <TextView
                android:textSize="@dimen/middle_text_size"
                android:textColor="@color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/stb_info_item_name_margin_left"
                android:text="@string/serial_number"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="@dimen/middle_text_size"
                android:textColor="@color/deep_blue"
                android:id="@+id/stb_info_serial_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/stb_info_item_text_margin_left"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:background="@drawable/add_time_down_back"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
            android:layout_marginRight="@dimen/space_of_to_mobile_side_size">
            <TextView
                android:textSize="@dimen/middle_text_size"
                android:textColor="@color/black"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/stb_info_item_name_margin_left"
                android:text="@string/channel_number"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="@dimen/middle_text_size"
                android:textColor="@color/deep_blue"
                android:id="@+id/stb_info_channel_number"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/stb_info_item_text_margin_left"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
    </LinearLayout>
    <include layout="@layout/ad_view_buttom_layout"/>
</LinearLayout>
