<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@drawable/backgound2"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <mktvsmart.screen.view.RemoteControlTouchPad
        android:id="@+id/touch_pad"
        android:background="@drawable/remote_control_touch_pad"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginTop="20dp"
        android:gestureStrokeType="multiple"/>
    <ImageView
        android:id="@+id/pad_indicator"
        android:background="@drawable/remote_control_pad_indicator"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"/>
</LinearLayout>
