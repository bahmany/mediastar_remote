<?xml version="1.0" encoding="utf-8"?>
<merge xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_gravity="top"
        android:id="@+id/player_overlay_header"
        android:background="#0000"
        android:paddingLeft="5dp"
        android:paddingRight="5dp"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true">
        <TextView
            android:textSize="15sp"
            android:textColor="#ffffff"
            android:id="@+id/player_overlay_title"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:layout_weight="1"/>
        <TextView
            android:textSize="15sp"
            android:textColor="#ffffff"
            android:id="@+id/player_overlay_battery"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="5dp"/>
        <TextView
            android:textSize="15sp"
            android:textColor="#ffffff"
            android:id="@+id/player_overlay_systime"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="bottom|right"
        android:orientation="vertical"
        android:id="@+id/option_overlay"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_above="@+id/bottom_View"
        android:layout_alignParentRight="true">
        <ImageButton
            android:id="@+id/player_overlay_back"
            android:background="@drawable/ic_backward_circle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
        <ImageButton
            android:id="@+id/player_overlay_size"
            android:background="@drawable/ic_crop_circle"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/bottom_View"
        android:background="#0000"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <RelativeLayout
            android:padding="5dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textSize="15sp"
                android:textColor="#ffffff"
                android:id="@+id/player_overlay_time"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="5dp"
                android:text="0:00"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"/>
            <SeekBar
                android:id="@+id/player_overlay_seekbar"
                android:paddingLeft="12dp"
                android:paddingRight="12dp"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:maxHeight="2dp"
                android:progressDrawable="@drawable/po_seekbar"
                android:minHeight="2dp"
                android:thumb="@drawable/seekbar_thumb"
                android:layout_toLeftOf="@+id/player_overlay_length"
                android:layout_toRightOf="@+id/player_overlay_time"
                android:layout_centerVertical="true"/>
            <TextView
                android:textSize="15sp"
                android:textColor="#ffffff"
                android:id="@+id/player_overlay_length"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="5dp"
                android:text="0:00"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:layout_width="match_parent"
            android:layout_height="60dp">
            <ImageButton
                android:id="@+id/player_overlay_backward"
                android:background="@drawable/ic_backward_w"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginRight="50dp"
                android:layout_toLeftOf="@+id/control_icon"
                android:layout_centerVertical="true"/>
            <ImageButton
                android:id="@+id/control_icon"
                android:background="@drawable/ic_play_circle_big_o"
                android:layout_width="60dp"
                android:layout_height="60dp"
                android:layout_centerInParent="true"
                android:contentDescription="@null"/>
            <ImageButton
                android:id="@+id/player_overlay_forward"
                android:background="@drawable/ic_forward_w"
                android:layout_width="40dp"
                android:layout_height="40dp"
                android:layout_marginLeft="50dp"
                android:layout_toRightOf="@+id/control_icon"
                android:layout_centerVertical="true"/>
            <ImageButton
                android:id="@+id/lock_overlay_button"
                android:background="@drawable/ic_lock"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
    </LinearLayout>
</merge>
