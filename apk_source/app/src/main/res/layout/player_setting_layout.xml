<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="wrap_content"
    android:layout_height="wrap_content">
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@+id/resolution_setting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <TextView
                android:textColor="@color/white"
                android:layout_width="120dp"
                android:layout_height="wrap_content"
                android:text="@string/str_resolution"/>
            <RadioGroup
                android:orientation="vertical"
                android:id="@+id/resolution_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <RadioButton
                    android:id="@+id/ratio_720x576"
                    android:tag="0"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    style="@style/CustomRadioBtn"/>
                <RadioButton
                    android:id="@+id/ratio_576x384"
                    android:tag="1"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    style="@style/CustomRadioBtn"/>
                <RadioButton
                    android:id="@+id/ratio_360x240"
                    android:tag="2"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    style="@style/CustomRadioBtn"/>
                <RadioButton
                    android:id="@+id/ratio_176"
                    android:tag="3"
                    android:layout_width="120dp"
                    android:layout_height="wrap_content"
                    style="@style/CustomRadioBtn"/>
            </RadioGroup>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@+id/birate_setting"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="20dp">
            <TextView
                android:textColor="@color/white"
                android:layout_width="100dp"
                android:layout_height="wrap_content"
                android:text="@string/str_bitrate"/>
            <RadioGroup
                android:orientation="vertical"
                android:id="@+id/bitrate_group"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content">
                <RadioButton
                    android:id="@+id/rate_500"
                    android:tag="0"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    style="@style/CustomRadioBtn"/>
                <RadioButton
                    android:id="@+id/rate_800"
                    android:tag="1"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    style="@style/CustomRadioBtn"/>
                <RadioButton
                    android:id="@+id/rate_1000"
                    android:tag="2"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    style="@style/CustomRadioBtn"/>
                <RadioButton
                    android:id="@+id/rate_1500"
                    android:tag="3"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    style="@style/CustomRadioBtn"/>
                <RadioButton
                    android:id="@+id/rate_5000"
                    android:tag="4"
                    android:layout_width="100dp"
                    android:layout_height="wrap_content"
                    style="@style/CustomRadioBtn"/>
            </RadioGroup>
        </LinearLayout>
    </LinearLayout>
</RelativeLayout>
