<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:ads="http://schemas.android.com/apk/res-auto"
    android:id="@+id/channel_content_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <FrameLayout
        android:id="@+id/player_surface_frame"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        android:foregroundGravity="clip_vertical|clip_horizontal">
        <SurfaceView
            android:id="@+id/player_surface"
            android:layout_width="1dp"
            android:layout_height="1dp"/>
        <SurfaceView
            android:id="@+id/subtitles_surface"
            android:layout_width="1dp"
            android:layout_height="1dp"/>
    </FrameLayout>
    <com.google.android.gms.ads.AdView
        android:id="@+id/wide_adView"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"
        ads:adSize="MEDIUM_RECTANGLE"
        ads:adUnitId="ca-app-pub-4741798363812571/2025927042"/>
    <TextView
        android:textSize="36sp"
        android:textColor="#ffffff"
        android:layout_gravity="center"
        android:id="@+id/player_overlay_info"
        android:background="@drawable/half_trans_bg"
        android:padding="5dp"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"/>
    <LinearLayout
        android:id="@+id/waitting_view"
        android:background="@color/black"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_centerInParent="true">
        <ProgressBar
            android:layout_gravity="center_vertical"
            android:id="@+id/waitting_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"/>
        <TextView
            android:layout_gravity="center"
            android:id="@+id/waitting_text"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"/>
    </LinearLayout>
    <FrameLayout
        android:orientation="horizontal"
        android:id="@+id/operation_volume_brightness"
        android:background="#00000000"
        android:padding="0dp"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/operation_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/video_volumn_bg"/>
        <FrameLayout
            android:layout_gravity="bottom|center_horizontal"
            android:paddingBottom="25dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_gravity="left"
                android:id="@+id/operation_full"
                android:layout_width="94dp"
                android:layout_height="wrap_content"
                android:src="@drawable/video_num_bg"/>
            <ImageView
                android:layout_gravity="left"
                android:id="@+id/operation_percent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:src="@drawable/video_num_front"
                android:scaleType="matrix"/>
        </FrameLayout>
    </FrameLayout>
    <mktvsmart.screen.vlc.PlayController
        android:id="@+id/play_controller"
        android:layout_width="match_parent"
        android:layout_height="match_parent"/>
</RelativeLayout>
