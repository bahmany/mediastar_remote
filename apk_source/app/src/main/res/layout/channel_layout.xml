<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/backgound2"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/channel_title"
        android:background="@drawable/disp_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/large_text_size"
            android:textColor="@color/title_text_color"
            android:id="@+id/title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerInParent="true"/>
        <ImageView
            android:textSize="@dimen/large_text_size"
            android:id="@+id/channel_type_arrow"
            android:background="@drawable/channel_type_right_arrow"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
            android:layout_toRightOf="@+id/title"
            android:layout_centerVertical="true"/>
        <LinearLayout
            android:gravity="center"
            android:id="@+id/all_selected_layout"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true">
            <ImageView
                android:id="@+id/all_selected"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_margin="@dimen/space_of_to_mobile_side_size"
                android:src="@drawable/none_selected"/>
        </LinearLayout>
        <Button
            android:textSize="@dimen/middle_text_size"
            android:id="@+id/editMode"
            android:background="@drawable/btn_click_menu"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/space_of_to_mobile_side_size"
            android:text="@string/edit_str"
            android:layout_alignParentRight="true"
            android:layout_centerVertical="true"/>
        <Button
            android:textSize="@dimen/middle_text_size"
            android:id="@+id/DoneMode"
            android:background="@drawable/btn_click_menu"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
            android:text="@string/finish_btn"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"/>
        <Button
            android:textSize="@dimen/middle_text_size"
            android:id="@+id/ChannelType"
            android:background="@drawable/btn_click_menu"
            android:visibility="visible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
            android:text="@string/type_tv"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <LinearLayout
        android:orientation="horizontal"
        android:background="@drawable/search_bg"
        android:paddingTop="@dimen/margin_small_little"
        android:paddingBottom="@dimen/margin_small_little"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <LinearLayout
            android:gravity="center_vertical"
            android:layout_gravity="center_vertical"
            android:orientation="horizontal"
            android:id="@+id/search_channel_layout"
            android:background="@drawable/search_fragment_bg"
            android:paddingTop="2dp"
            android:paddingBottom="2dp"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
            android:layout_marginRight="@dimen/space_of_to_mobile_side_size"
            android:layout_weight="1">
            <ImageView
                android:id="@+id/search_icon"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="@dimen/margin_small_little"
                android:src="@drawable/search_icon"/>
            <EditText
                android:textColor="@color/white"
                android:id="@+id/search_channel_text"
                android:background="@null"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:singleLine="true"
                android:layout_weight="1"
                android:inputType="textNoSuggestions"/>
            <ImageView
                android:id="@+id/clear_search_input"
                android:visibility="gone"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/margin_small_little"
                android:src="@drawable/search_delete_icon"/>
        </LinearLayout>
        <Button
            android:textSize="@dimen/middle_text_size"
            android:gravity="center"
            android:layout_gravity="center_vertical"
            android:id="@+id/search_cancel"
            android:background="@drawable/cancel_btn_click_menu"
            android:visibility="gone"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginRight="@dimen/space_of_to_mobile_side_size"
            android:text="@string/cancel_search"
            android:singleLine="true"/>
    </LinearLayout>
    <LinearLayout
        android:gravity="center"
        android:id="@+id/search_failed"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <TextView
            android:textSize="@dimen/large_text_size"
            android:textColor="@color/black"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/prompt_info"/>
    </LinearLayout>
    <FrameLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_weight="1">
        <ListView
            android:id="@+id/channel_list"
            android:background="@drawable/backgound2"
            android:fadingEdge="none"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:fastScrollEnabled="true"/>
    </FrameLayout>
    <LinearLayout
        android:layout_gravity="bottom"
        android:orientation="horizontal"
        android:id="@+id/edit_menu"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:baselineAligned="false">
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@+id/edit_move_menu"
            android:background="@drawable/edit_menu_background"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <ImageView
                android:id="@+id/edit_move"
                android:background="@drawable/move_unuse"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
            <TextView
                android:textSize="@dimen/tiny_text_size"
                android:textColor="@color/white"
                android:id="@+id/edit_move_string"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_move"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@+id/edit_rename_menu"
            android:background="@drawable/edit_menu_item_background"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <ImageView
                android:id="@+id/edit_rename"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/rename_unuse"/>
            <TextView
                android:textSize="@dimen/tiny_text_size"
                android:textColor="@color/white"
                android:id="@+id/edit_rename_string"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_rename"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@+id/edit_delete_menu"
            android:background="@drawable/edit_menu_item_background"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <ImageView
                android:id="@+id/edit_delete"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/delete_unuse"/>
            <TextView
                android:textSize="@dimen/tiny_text_size"
                android:textColor="@color/white"
                android:id="@+id/edit_delete_string"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_delete"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@+id/edit_lock_menu"
            android:background="@drawable/edit_menu_item_background"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <ImageView
                android:id="@+id/edit_lock"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/lock_unuse"/>
            <TextView
                android:textSize="@dimen/tiny_text_size"
                android:textColor="@color/white"
                android:id="@+id/edit_lock_string"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_lock"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@+id/edit_favor_menu"
            android:background="@drawable/edit_menu_item_background"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <ImageView
                android:id="@+id/edit_favor"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/favor_unuse"/>
            <TextView
                android:textSize="@dimen/tiny_text_size"
                android:textColor="@color/white"
                android:id="@+id/edit_favor_string"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_favor"/>
        </LinearLayout>
        <LinearLayout
            android:gravity="center_horizontal"
            android:orientation="vertical"
            android:id="@+id/edit_sort_menu"
            android:background="@drawable/edit_menu_item_background"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_weight="1">
            <ImageView
                android:id="@+id/edit_sort"
                android:clickable="false"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/sort_btn_unuse"/>
            <TextView
                android:textSize="@dimen/tiny_text_size"
                android:textColor="@color/white"
                android:id="@+id/edit_sort_string"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/edit_sort"/>
        </LinearLayout>
    </LinearLayout>
</LinearLayout>
