<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android" xmlns:ads="http://schemas.android.com/apk/lib/com.google.ads"
    android:id="@+id/channel_content_layout"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <io.vov.vitamio.widget.CenterLayout
        android:orientation="vertical"
        android:focusable="false"
        android:focusableInTouchMode="false"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <io.vov.vitamio.widget.VideoView
            android:id="@+id/video_view"
            android:focusable="false"
            android:focusableInTouchMode="false"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:layout_centerHorizontal="true"
            android:layout_centerVertical="true"/>
    </io.vov.vitamio.widget.CenterLayout>
    <TextView
        android:textSize="36sp"
        android:textColor="#ffffff"
        android:layout_gravity="center"
        android:id="@+id/player_overlay_info"
        android:background="@drawable/half_trans_bg"
        android:padding="5dp"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true"/>
    <LinearLayout
        android:id="@+id/buffering_view"
        android:background="@color/black"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="60dp"
        android:layout_centerInParent="true">
        <ProgressBar
            android:layout_gravity="center_vertical"
            android:id="@+id/buffering_progress"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="10dp"/>
        <TextView
            android:layout_gravity="center"
            android:id="@+id/buffering_text"
            android:layout_width="150dp"
            android:layout_height="wrap_content"
            android:layout_marginLeft="15dp"/>
    </LinearLayout>
    <LinearLayout
        android:orientation="vertical"
        android:id="@+id/left_channel_layout"
        android:background="@color/transparent"
        android:layout_width="320dp"
        android:layout_height="match_parent"
        android:layout_alignParentLeft="true">
        <ListView
            android:id="@+id/channel_list_view"
            android:background="@drawable/half_trans_bg"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:listSelector="@drawable/list_item_selector_style"
            android:drawSelectorOnTop="false"
            android:cacheColorHint="@color/transparent"
            android:divider="@drawable/line"
            android:layout_weight="1"
            android:fastScrollEnabled="true"/>
    </LinearLayout>
    <RelativeLayout
        android:id="@+id/player_ctrl_view"
        android:background="@null"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:baselineAligned="false">
        <RelativeLayout
            android:id="@+id/top_layout"
            android:background="@drawable/half_trans_bg"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_alignParentTop="true">
            <ImageView
                android:id="@+id/back_icon"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:src="@drawable/player_back_bg"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:contentDescription="@null"/>
            <TextView
                android:id="@+id/program_name"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_centerInParent="true"/>
            <ImageView
                android:id="@+id/play_setting"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:src="@drawable/player_setting_bg"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"/>
        </RelativeLayout>
        <RelativeLayout
            android:id="@+id/bottom_layout"
            android:background="@drawable/half_trans_bg"
            android:layout_width="match_parent"
            android:layout_height="60dp"
            android:layout_alignParentBottom="true">
            <ImageView
                android:id="@+id/channel_list_icon"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginLeft="10dp"
                android:src="@drawable/player_channellist_bg"
                android:layout_alignParentLeft="true"
                android:layout_centerVertical="true"
                android:contentDescription="@null"/>
            <ImageView
                android:id="@+id/control_icon"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:src="@drawable/play_start_selector"
                android:layout_centerInParent="true"
                android:contentDescription="@null"/>
            <ImageView
                android:id="@+id/screen_size_icon"
                android:clickable="true"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="10dp"
                android:src="@drawable/play_screen_suitable_gnr"
                android:layout_alignParentRight="true"
                android:layout_centerVertical="true"
                android:contentDescription="@null"/>
        </RelativeLayout>
    </RelativeLayout>
    <FrameLayout
        android:orientation="horizontal"
        android:id="@+id/operation_volume_brightness"
        android:background="#00000000"
        android:padding="0dp"
        android:visibility="invisible"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_centerInParent="true">
        <ImageView
            android:layout_gravity="center"
            android:id="@+id/operation_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:src="@drawable/video_volumn_bg"/>
        <FrameLayout
            android:layout_gravity="bottom|center_horizontal"
            android:paddingBottom="25dp"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content">
            <ImageView
                android:layout_gravity="left"
                android:id="@+id/operation_full"
                android:layout_width="94dp"
                android:layout_height="wrap_content"
                android:src="@drawable/video_num_bg"/>
            <ImageView
                android:layout_gravity="left"
                android:id="@+id/operation_percent"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:src="@drawable/video_num_front"
                android:scaleType="matrix"/>
        </FrameLayout>
    </FrameLayout>
    <TextView
        android:id="@+id/down_rate"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentRight="true"
        android:layout_alignParentBottom="true"/>
    <FrameLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:layout_centerHorizontal="true">
        <com.google.ads.AdView
            android:id="@+id/adView"
            android:visibility="invisible"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            ads:adSize="BANNER"
            ads:adUnitId="ca-app-pub-1312448400103996/4277896266"
            ads:loadAdOnCreate="true"/>
    </FrameLayout>
</RelativeLayout>
