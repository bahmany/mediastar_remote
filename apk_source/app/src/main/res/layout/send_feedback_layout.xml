<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_horizontal"
    android:orientation="vertical"
    android:background="@drawable/backgound2"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:background="@drawable/disp_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/large_text_size"
            android:textColor="@color/title_text_color"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/advice_feedback"
            android:layout_centerInParent="true"/>
        <Button
            android:id="@+id/back_send_feedback"
            android:background="@drawable/return_button_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <EditText
        android:gravity="top"
        android:id="@+id/feedback_edit_txt"
        android:background="@drawable/edittext_background"
        android:scrollbars="vertical"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="40dp"
        android:layout_marginTop="20dp"
        android:layout_marginRight="40dp"
        android:maxHeight="188dp"
        android:minHeight="188dp"
        android:ems="10"
        android:inputType="textNoSuggestions">
        <requestFocus/>
    </EditText>
    <Button
        android:textSize="@dimen/middle_text_size"
        android:textColor="@color/white"
        android:id="@+id/btn_send_feedback"
        android:background="@drawable/button_send_advice_bg"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="40dp"
        android:layout_marginTop="10dp"
        android:layout_marginRight="40dp"
        android:text="@string/send_str"/>
</LinearLayout>
