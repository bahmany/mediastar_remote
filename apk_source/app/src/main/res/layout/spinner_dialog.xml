<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@android:color/background_light"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/title"
        android:background="@drawable/disp_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/large_text_size"
            android:textColor="@color/title_text_color"
            android:id="@+id/label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/event_channel"
            android:layout_centerInParent="true"/>
    </RelativeLayout>
    <ListView
        android:id="@+id/formcustomspinner_list"
        android:scrollbars="none"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:cacheColorHint="@null"
        android:divider="@android:drawable/divider_horizontal_bright"
        android:layout_weight="1"
        android:fastScrollEnabled="true"/>
    <Button
        android:id="@+id/spiner_dialog_cancel_btn"
        android:background="@drawable/btn_click_blue"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="@string/cancel_str"/>
</LinearLayout>
