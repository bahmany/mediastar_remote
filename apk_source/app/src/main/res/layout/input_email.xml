<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/input_email_addr_txt"
            android:layout_width="65dp"
            android:layout_height="wrap_content"
            android:text="@string/user_email_address"/>
        <EditText
            android:id="@+id/input_email_addr_edit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ems="10"
            android:layout_weight="1"
            android:inputType="textNoSuggestions">
            <requestFocus/>
        </EditText>
    </LinearLayout>
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:id="@+id/input_email_pwd_txt"
            android:layout_width="65dp"
            android:layout_height="wrap_content"
            android:text="@string/user_email_password"/>
        <EditText
            android:id="@+id/input_email_pwd_edit"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:ems="10"
            android:layout_weight="1"
            android:inputType="textPassword"/>
    </LinearLayout>
</LinearLayout>
