<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:gravity="center_vertical"
    android:orientation="horizontal"
    android:paddingTop="@dimen/margin_small_little"
    android:paddingBottom="@dimen/margin_small_little"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:baselineAligned="false">
    <ImageView
        android:id="@+id/head_icon"
        android:background="@drawable/gchat_head_icon"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:contentDescription="@null"/>
    <RelativeLayout
        android:orientation="vertical"
        android:paddingLeft="@dimen/margin_little"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1">
        <TextView
            android:textSize="16sp"
            android:textColor="@color/black"
            android:id="@+id/user_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_centerVertical="true"/>
        <TextView
            android:textSize="@dimen/ultra_small_text_size"
            android:textColor="@color/gchat_userlist_bottom_bar_light_bg"
            android:id="@+id/user_id"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/margin_small"
            android:layout_below="@+id/user_name"/>
    </RelativeLayout>
    <ImageView
        android:id="@+id/block_icon"
        android:background="@drawable/gchat_block_icon"
        android:visibility="gone"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_marginRight="@dimen/margin_little"
        android:contentDescription="@null"/>
</LinearLayout>
