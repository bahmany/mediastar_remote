<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@drawable/backgound2"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <LinearLayout
        android:gravity="center"
        android:id="@+id/remote_layout_title"
        android:background="@drawable/disp_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/large_text_size"
            android:textColor="@color/title_text_color"
            android:id="@+id/sys_settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/remote_tab_title"/>
    </LinearLayout>
    <FrameLayout
        android:orientation="vertical"
        android:id="@+id/remote_pages"
        android:layout_width="match_parent"
        android:layout_height="match_parent">
        <mktvsmart.screen.view.GsViewPager
            android:id="@+id/remote_pager"
            android:layout_width="match_parent"
            android:layout_height="match_parent"/>
        <LinearLayout
            android:gravity="center"
            android:layout_gravity="top"
            android:id="@+id/dot_group_layout"
            android:paddingTop="8dp"
            android:layout_width="match_parent"
            android:layout_height="wrap_content">
            <ImageView
                android:id="@+id/remote_page_dot_0"
                android:background="@drawable/view_pager_dot_selected"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="8dp"/>
            <ImageView
                android:id="@+id/remote_page_dot_1"
                android:background="@drawable/view_pager_dot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="8dp"/>
            <ImageView
                android:id="@+id/remote_page_dot_2"
                android:background="@drawable/view_pager_dot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="8dp"/>
            <ImageView
                android:id="@+id/remote_page_dot_3"
                android:background="@drawable/view_pager_dot"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"/>
        </LinearLayout>
    </FrameLayout>
</LinearLayout>
