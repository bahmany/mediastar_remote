<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:gravity="center_vertical"
        android:id="@+id/pop_window_list_name"
        android:background="@drawable/disp_channel"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/middle_text_size"
            android:textColor="@color/black"
            android:id="@+id/list_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
            android:maxLength="26"
            android:layout_alignParentLeft="true"/>
        <LinearLayout
            android:gravity="center"
            android:id="@+id/pop_window_list_select"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_alignTop="@+id/list_name"
            android:layout_alignParentRight="true">
            <ImageView
                android:id="@+id/list_select"
                android:padding="@dimen/pop_window_list_padding"
                android:visibility="visible"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:layout_marginRight="@dimen/space_of_to_mobile_side_size"
                android:src="@drawable/list_unselected"/>
        </LinearLayout>
    </RelativeLayout>
</LinearLayout>
