<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:background="@drawable/backgound2"
    android:layout_width="match_parent"
    android:layout_height="match_parent">
    <RelativeLayout
        android:id="@+id/relative_layout01"
        android:background="@drawable/disp_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/large_text_size"
            android:textColor="@color/title_text_color"
            android:id="@+id/g_settings_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/player_setting"
            android:layout_centerInParent="true"/>
        <Button
            android:id="@+id/back_btn"
            android:background="@drawable/return_button_bg"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
            android:layout_alignParentLeft="true"
            android:layout_centerVertical="true"/>
    </RelativeLayout>
    <ScrollView
        android:id="@+id/setting_scroll"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_above="@+id/linear_layout01"
        android:layout_below="@+id/relative_layout01">
        <LinearLayout
            android:orientation="vertical"
            android:id="@+id/scroll_setting_item"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"/>
    </ScrollView>
    <LinearLayout
        android:id="@+id/linear_layout01"
        android:visibility="gone"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentBottom="true">
        <Button
            android:id="@+id/save_btn"
            android:background="@drawable/btn_click_left"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/save_str"
            android:layout_weight="1"/>
        <Button
            android:id="@+id/cancel_btn"
            android:background="@drawable/btn_click_right"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/cancel_str"
            android:layout_weight="1"/>
    </LinearLayout>
</RelativeLayout>
