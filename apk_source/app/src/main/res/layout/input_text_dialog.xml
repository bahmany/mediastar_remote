<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical"
    android:background="@color/white"
    android:layout_width="match_parent"
    android:layout_height="wrap_content">
    <LinearLayout
        android:gravity="center"
        android:background="@drawable/disp_title"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <TextView
            android:textSize="@dimen/large_text_size"
            android:textColor="@color/title_text_color"
            android:id="@+id/input_text_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"/>
    </LinearLayout>
    <TextView
        android:textSize="@dimen/middle_text_size"
        android:textColor="@color/black"
        android:id="@+id/input_text_dialog_txt"
        android:layout_width="300dp"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
        android:layout_marginTop="20dp"
        android:layout_marginRight="@dimen/space_of_to_mobile_side_size"/>
    <EditText
        android:id="@+id/input_text_edittext"
        android:background="@drawable/edittext_background"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_marginLeft="@dimen/space_of_to_mobile_side_size"
        android:layout_marginTop="10dp"
        android:layout_marginRight="@dimen/space_of_to_mobile_side_size"
        android:layout_marginBottom="20dp"
        android:ems="10"
        android:inputType="textNoSuggestions">
        <requestFocus/>
    </EditText>
    <LinearLayout
        android:orientation="horizontal"
        android:layout_width="match_parent"
        android:layout_height="wrap_content">
        <Button
            android:id="@+id/input_text_confirm_btn"
            android:background="@drawable/btn_click_left"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/confirm_str"
            android:layout_weight="1"/>
        <Button
            android:id="@+id/input_text_cancel_btn"
            android:background="@drawable/btn_click_right"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/cancel_str"
            android:layout_weight="1"/>
    </LinearLayout>
</LinearLayout>
